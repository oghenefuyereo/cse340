<section class="vehicle-details">
  <!-- Vehicle Image Section -->
  <div class="vehicle-image-section">
    <img src="<%= vehicle.inv_image %>" alt="Image of <%= vehicle.inv_make %> <%= vehicle.inv_model %>"
      class="vehicle-image">
    <p class="certification-banner">
      This vehicle has passed inspection by an ASE-certified technician.
    </p>
  </div>

  <!-- Vehicle Info Section -->
  <div class="vehicle-info-section">
    <h1 class="vehicle-title">
      <%= vehicle.inv_year %>
        <%= vehicle.inv_make %>
          <%= vehicle.inv_model %>
    </h1>

    <!-- Price -->
    <p class="vehicle-price">
      <strong>No-Haggle Price:</strong>
      <%= utilities.formatCurrency(vehicle.inv_price) %>
    </p>

    <!-- Mileage -->
    <p class="vehicle-mileage">
      <strong>Mileage:</strong>
      <%= utilities.formatMileage(vehicle.inv_miles) %> miles
    </p>

    <!-- Description -->
    <p class="vehicle-description">
      <strong>Description:</strong>
      <%= vehicle.inv_description %>
    </p>

    <!-- Vehicle Specifications (Optional) -->
    <% if (vehicle.inv_engine) { %>
      <p class="vehicle-spec">
        <strong>Engine:</strong>
        <%= vehicle.inv_engine %>
      </p>
      <% } %>

        <% if (vehicle.inv_transmission) { %>
          <p class="vehicle-spec">
            <strong>Transmission:</strong>
            <%= vehicle.inv_transmission %>
          </p>
          <% } %>

            <% if (vehicle.inv_color) { %>
              <p class="vehicle-spec">
                <strong>Color:</strong>
                <%= vehicle.inv_color %>
              </p>
              <% } %>

                <!-- Action Buttons -->
                <div class="action-buttons">
                  <button class="btn-action">Start My Purchase</button>
                  <button class="btn-action">Contact Us</button>
                  <button class="btn-action">Schedule Test Drive</button>
                  <button class="btn-action">Apply for Financing</button>
                </div>
  </div>
</section>